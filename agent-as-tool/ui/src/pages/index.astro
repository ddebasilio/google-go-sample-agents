---
const adkUrl =
  import.meta.env.ADK_URL ??
  "https://adk-default-service-name-841572325613.europe-west3.run.app";
const adkApp = import.meta.env.ADK_APP ?? "agent";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>research_root chat</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />
    <style is:global>
      :root {
        color-scheme: light dark;
        --bg: #0b0d12;
        --bg-elev: #11141b;
        --panel: #161a22;
        --panel-2: #1c2230;
        --border: #232936;
        --border-strong: #2f3749;
        --muted: #8a93a6;
        --muted-2: #5a6275;
        --fg: #e6e9ef;
        --accent: #7aa2ff;
        --accent-2: #4d7bff;
        --user-bg: #2b3a55;
        --user-fg: #eaf0ff;
        --bubble-bg: #161a22;
        --tool-bg: #14201a;
        --tool-fg: #a7d4b3;
        --error-bg: #3a1a1f;
        --error-fg: #ffb3bd;
        --c-root: #c4b5fd;
        --c-researcher: #93c5fd;
        --c-critic: #fcd34d;
        --c-user: #67e8f9;
      }
      * { box-sizing: border-box; }
      html, body { height: 100%; margin: 0; }
      body {
        font-family: "Inter", -apple-system, BlinkMacSystemFont, system-ui, sans-serif;
        font-size: 14.5px;
        line-height: 1.55;
        background:
          radial-gradient(1200px 600px at 80% -10%, rgba(122,162,255,0.08), transparent 60%),
          radial-gradient(900px 500px at -10% 110%, rgba(196,181,253,0.07), transparent 60%),
          var(--bg);
        color: var(--fg);
        display: flex;
        flex-direction: column;
      }

      header {
        padding: 14px 22px;
        border-bottom: 1px solid var(--border);
        display: flex;
        align-items: center;
        gap: 14px;
        background: rgba(11,13,18,0.6);
        backdrop-filter: blur(8px);
        position: sticky;
        top: 0;
        z-index: 10;
      }
      header .brand {
        display: flex;
        align-items: center;
        gap: 10px;
      }
      header .dot {
        width: 8px; height: 8px; border-radius: 50%;
        background: #46d27a;
        box-shadow: 0 0 12px rgba(70,210,122,0.6);
      }
      header h1 {
        margin: 0;
        font-size: 14px;
        font-weight: 600;
        letter-spacing: 0.02em;
      }
      header .meta {
        color: var(--muted);
        font-size: 12px;
        margin-left: auto;
        font-family: "JetBrains Mono", ui-monospace, monospace;
      }
      header button {
        background: var(--panel);
        border: 1px solid var(--border);
        color: var(--fg);
        padding: 6px 12px;
        border-radius: 8px;
        cursor: pointer;
        font-size: 12.5px;
        font-weight: 500;
        transition: border-color 0.15s, transform 0.05s;
      }
      header button:hover { border-color: var(--accent); }
      header button:active { transform: translateY(1px); }

      main {
        flex: 1;
        overflow-y: auto;
        padding: 24px 22px 32px;
        display: flex;
        flex-direction: column;
        gap: 14px;
        max-width: 900px;
        width: 100%;
        margin: 0 auto;
      }

      .turn {
        display: flex;
        gap: 12px;
        align-items: flex-end;
      }
      .turn.right {
        flex-direction: row-reverse;
      }
      .avatar {
        width: 34px;
        height: 34px;
        border-radius: 50%;
        display: grid;
        place-items: center;
        flex: 0 0 auto;
        background: var(--panel-2);
        border: 1px solid var(--border-strong);
        font-size: 16px;
        line-height: 1;
        margin-bottom: 4px;
      }
      .avatar.user { background: linear-gradient(135deg, #1b3a5b, #2b4f7a); border-color: #335a87; }
      .avatar.research_root { background: linear-gradient(135deg, #2a1f4a, #3a2c66); border-color: #4a3a82; }
      .avatar.researcher { background: linear-gradient(135deg, #16324a, #21476a); border-color: #2f5d8a; }
      .avatar.critic { background: linear-gradient(135deg, #3a2d10, #54421a); border-color: #7a6325; }

      .col {
        display: flex;
        flex-direction: column;
        gap: 4px;
        max-width: min(72ch, 80%);
      }
      .turn.right .col { align-items: flex-end; }
      .who {
        font-size: 11px;
        color: var(--muted);
        text-transform: uppercase;
        letter-spacing: 0.06em;
        font-weight: 600;
        padding: 0 6px;
      }
      .who.research_root { color: var(--c-root); }
      .who.researcher { color: var(--c-researcher); }
      .who.critic { color: var(--c-critic); }
      .who.user { color: var(--c-user); }

      .bubble {
        position: relative;
        padding: 11px 15px;
        border-radius: 14px;
        background: var(--bubble-bg);
        border: 1px solid var(--border);
        word-wrap: break-word;
      }
      .turn:not(.right) .bubble {
        border-top-left-radius: 4px;
      }
      .turn.right .bubble {
        background: var(--user-bg);
        color: var(--user-fg);
        border-top-right-radius: 4px;
        border-color: #355080;
      }
      .turn:not(.right) .bubble::before {
        content: "";
        position: absolute;
        top: 0; left: -7px;
        width: 14px; height: 14px;
        background: var(--bubble-bg);
        border-left: 1px solid var(--border);
        border-top: 1px solid var(--border);
        clip-path: polygon(0 0, 100% 0, 100% 100%);
      }
      .turn.right .bubble::after {
        content: "";
        position: absolute;
        top: 0; right: -7px;
        width: 14px; height: 14px;
        background: var(--user-bg);
        border-right: 1px solid #355080;
        border-top: 1px solid #355080;
        clip-path: polygon(0 0, 100% 0, 0 100%);
      }

      .debug {
        margin: 2px 0 2px 46px;
        font-family: "JetBrains Mono", ui-monospace, monospace;
        font-size: 12px;
        color: var(--muted);
        border-left: 2px solid var(--border);
        padding-left: 10px;
      }
      .debug details > summary {
        cursor: pointer;
        list-style: none;
        display: flex;
        align-items: center;
        gap: 6px;
        padding: 2px 0;
        color: var(--muted);
      }
      .debug details > summary:hover { color: var(--fg); }
      .debug details > summary::-webkit-details-marker { display: none; }
      .debug .arrow { color: var(--muted-2); font-weight: 600; }
      .debug.call .arrow { color: #8ab2ff; }
      .debug.result .arrow { color: #7ec48f; }
      .debug .name { color: var(--fg); font-weight: 500; }
      .debug .who-tag { color: var(--muted-2); }
      .debug .chev {
        margin-left: auto;
        opacity: 0.5;
        transition: transform 0.15s;
        font-size: 10px;
      }
      .debug details[open] .chev { transform: rotate(90deg); }
      .debug pre {
        margin: 4px 0 6px;
        padding: 8px 10px;
        background: rgba(255,255,255,0.03);
        border: 1px dashed var(--border);
        border-radius: 6px;
        font-size: 11.5px;
        white-space: pre-wrap;
        word-wrap: break-word;
        max-height: 320px;
        overflow: auto;
        color: var(--muted);
      }

      .bubble.error {
        background: var(--error-bg);
        color: var(--error-fg);
        border-color: #6a2a32;
      }

      /* markdown */
      .md > :first-child { margin-top: 0; }
      .md > :last-child { margin-bottom: 0; }
      .md p { margin: 0.4em 0; }
      .md ul, .md ol { margin: 0.4em 0; padding-left: 1.4em; }
      .md li { margin: 0.15em 0; }
      .md h1, .md h2, .md h3, .md h4 {
        margin: 0.6em 0 0.3em;
        font-weight: 600;
        line-height: 1.25;
      }
      .md h1 { font-size: 1.3em; }
      .md h2 { font-size: 1.18em; }
      .md h3 { font-size: 1.07em; }
      .md h4 { font-size: 1em; }
      .md a {
        color: var(--accent);
        text-decoration: none;
        border-bottom: 1px dotted rgba(122,162,255,0.5);
      }
      .md a:hover { border-bottom-style: solid; }
      .md code {
        font-family: "JetBrains Mono", ui-monospace, monospace;
        font-size: 0.9em;
        background: rgba(255,255,255,0.08);
        padding: 1px 5px;
        border-radius: 4px;
      }
      .md pre {
        background: #0a0d14;
        border: 1px solid var(--border);
        border-radius: 8px;
        padding: 10px 12px;
        overflow: auto;
        margin: 0.5em 0;
      }
      .md pre code {
        background: transparent;
        padding: 0;
        font-size: 12.5px;
      }
      .md blockquote {
        margin: 0.4em 0;
        padding: 4px 12px;
        border-left: 3px solid var(--accent-2);
        color: var(--muted);
      }
      .md hr {
        border: 0;
        border-top: 1px solid var(--border);
        margin: 0.6em 0;
      }
      .md table {
        border-collapse: collapse;
        margin: 0.4em 0;
      }
      .md th, .md td {
        border: 1px solid var(--border);
        padding: 4px 8px;
      }

      .thinking {
        display: flex;
        align-items: center;
        gap: 8px;
        color: var(--muted);
        font-style: italic;
        padding: 4px 12px;
        font-size: 12.5px;
      }
      .thinking .dots {
        display: inline-flex;
        gap: 3px;
      }
      .thinking .dots span {
        width: 5px; height: 5px; border-radius: 50%;
        background: var(--muted);
        animation: pulse 1.2s ease-in-out infinite;
      }
      .thinking .dots span:nth-child(2) { animation-delay: 0.2s; }
      .thinking .dots span:nth-child(3) { animation-delay: 0.4s; }
      @keyframes pulse {
        0%, 60%, 100% { opacity: 0.25; transform: scale(0.9); }
        30% { opacity: 1; transform: scale(1.1); }
      }

      footer {
        border-top: 1px solid var(--border);
        padding: 14px 22px 18px;
        background: rgba(11,13,18,0.7);
        backdrop-filter: blur(8px);
      }
      form {
        max-width: 900px;
        margin: 0 auto;
        display: flex;
        gap: 10px;
        align-items: flex-end;
      }
      textarea {
        flex: 1;
        resize: none;
        height: 48px;
        min-height: 48px;
        max-height: 200px;
        padding: 12px 14px;
        border-radius: 12px;
        border: 1px solid var(--border-strong);
        background: var(--panel);
        color: var(--fg);
        font-family: inherit;
        font-size: 14.5px;
        line-height: 24px;
        transition: border-color 0.15s, box-shadow 0.15s;
        overflow-y: auto;
      }
      textarea:focus {
        outline: none;
        border-color: var(--accent);
        box-shadow: 0 0 0 3px rgba(122,162,255,0.15);
      }
      button.send {
        height: 48px;
        padding: 0 20px;
        border-radius: 12px;
        border: 1px solid var(--accent);
        background: linear-gradient(135deg, var(--accent), var(--accent-2));
        color: #0b1220;
        font-weight: 600;
        font-size: 14px;
        cursor: pointer;
        display: flex;
        align-items: center;
        gap: 8px;
        transition: transform 0.05s, opacity 0.15s;
      }
      button.send:hover:not([disabled]) { transform: translateY(-1px); }
      button.send[disabled] { opacity: 0.4; cursor: not-allowed; }
      button.send svg { width: 16px; height: 16px; }
    </style>
  </head>
  <body>
    <header>
      <div class="brand">
        <span class="dot"></span>
        <h1>research_root</h1>
      </div>
      <span class="meta" id="session-meta">no session</span>
      <button id="new-session" type="button">New session</button>
    </header>
    <main id="log" aria-live="polite"></main>
    <footer>
      <form id="chat-form">
        <textarea
          id="input"
          rows="1"
          placeholder="Ask the researcher something… (Enter to send, Shift+Enter for newline)"
          autocomplete="off"
        ></textarea>
        <button type="submit" class="send" id="send">
          <span>Send</span>
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
        </button>
      </form>
    </footer>

    <script type="module" define:vars={{ adkUrl, adkApp }}>
      import { marked } from "https://esm.sh/marked@14";
      import DOMPurify from "https://esm.sh/dompurify@3";

      marked.setOptions({ gfm: true, breaks: true });

      const log = document.getElementById("log");
      const form = document.getElementById("chat-form");
      const input = document.getElementById("input");
      const sendBtn = document.getElementById("send");
      const newBtn = document.getElementById("new-session");
      const meta = document.getElementById("session-meta");

      const AGENT_ICONS = {
        user: "👤",
        research_root: "🧭",
        researcher: "🔍",
        critic: "⚖️",
      };
      const iconFor = (who) => AGENT_ICONS[who] ?? "🤖";

      const state = {
        sessionId: sessionStorage.getItem("sessionId") || null,
        pending: false,
      };
      renderMeta();

      function renderMeta() {
        meta.textContent = state.sessionId
          ? `${state.sessionId} · ${adkApp}@${new URL(adkUrl).host}`
          : `no session · ${adkApp}@${new URL(adkUrl).host}`;
      }

      function el(tag, className, text) {
        const e = document.createElement(tag);
        if (className) e.className = className;
        if (text !== undefined) e.textContent = text;
        return e;
      }

      function safeMd(text) {
        const html = marked.parse(text ?? "", { async: false });
        return DOMPurify.sanitize(html, { ADD_ATTR: ["target", "rel"] });
      }

      function addTurn(who, { side = "left", bubbleClass = "", markdown = false, text = "" } = {}) {
        const turn = el("div", `turn ${side === "right" ? "right" : ""}`);
        const avatar = el("div", `avatar ${who}`);
        avatar.textContent = iconFor(who);
        const col = el("div", "col");
        col.append(el("div", `who ${who}`, who));
        const bubble = el("div", `bubble ${bubbleClass}`);
        if (markdown) {
          const md = el("div", "md");
          md.innerHTML = safeMd(text);
          enhanceLinks(md);
          bubble.append(md);
        } else {
          bubble.textContent = text;
        }
        col.append(bubble);
        turn.append(avatar, col);
        log.append(turn);
        scroll();
        return { turn, bubble };
      }

      function addDebug(kind, author, name, payload) {
        const row = el("div", `debug ${kind}`);
        const details = el("details");
        const summary = el("summary");
        const arrow = el("span", "arrow", kind === "call" ? "→" : "←");
        const who = el("span", "who-tag", author);
        const sep1 = el("span", null, " ");
        const verb = el("span", null, kind === "call" ? "calls" : "returns from");
        const sep2 = el("span", null, " ");
        const nameEl = el("span", "name", kind === "call" ? `${name}()` : name);
        const chev = el("span", "chev", "▶");
        summary.append(arrow, who, sep1, verb, sep2, nameEl, chev);
        const text =
          typeof payload === "string"
            ? payload
            : JSON.stringify(payload ?? {}, null, 2);
        const pre = el("pre", null, text);
        details.append(summary, pre);
        row.append(details);
        log.append(row);
        scroll();
      }

      function addToolCall(author, name, args) {
        addDebug("call", author, name, args);
      }

      function addToolResult(author, name, response) {
        addDebug("result", author, name, response);
      }

      function addError(message) {
        const turn = el("div", "turn");
        turn.append(el("div", "avatar", "⚠️"));
        const col = el("div", "col");
        col.append(el("div", "who", "error"));
        col.append(el("div", "bubble error", message));
        turn.append(col);
        log.append(turn);
        scroll();
      }

      function enhanceLinks(root) {
        for (const a of root.querySelectorAll("a")) {
          a.setAttribute("target", "_blank");
          a.setAttribute("rel", "noopener noreferrer");
        }
      }

      function addThinking() {
        const wrap = el("div", "thinking");
        const dots = el("span", "dots");
        dots.append(el("span"), el("span"), el("span"));
        const label = el("span", null, "thinking");
        wrap.append(dots, label);
        log.append(wrap);
        scroll();
        const started = Date.now();
        const timer = setInterval(() => {
          const s = Math.round((Date.now() - started) / 1000);
          label.textContent = `thinking · ${s}s`;
        }, 250);
        return () => {
          clearInterval(timer);
          wrap.remove();
        };
      }

      function scroll() {
        log.scrollTop = log.scrollHeight;
      }

      async function send(message) {
        if (state.pending) return;
        state.pending = true;
        sendBtn.disabled = true;
        addTurn("user", { side: "right", text: message });
        const stop = addThinking();
        let stopped = false;
        const stopOnce = () => { if (!stopped) { stopped = true; stop(); } };

        try {
          const res = await fetch("/api/chat-stream", {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({
              sessionId: state.sessionId,
              message,
            }),
          });
          if (!res.ok || !res.body) {
            const t = await res.text().catch(() => "");
            stopOnce();
            addError(`HTTP ${res.status} ${t}`);
            return;
          }

          const reader = res.body.getReader();
          const decoder = new TextDecoder();
          let buffer = "";

          while (true) {
            const { value, done } = await reader.read();
            if (done) break;
            buffer += decoder.decode(value, { stream: true });
            let sep;
            while ((sep = buffer.indexOf("\n\n")) !== -1) {
              const frame = buffer.slice(0, sep);
              buffer = buffer.slice(sep + 2);
              let event = "message";
              const dataLines = [];
              for (const line of frame.split("\n")) {
                if (line.startsWith("event:")) event = line.slice(6).trim();
                else if (line.startsWith("data:")) dataLines.push(line.slice(5).replace(/^ /, ""));
              }
              if (dataLines.length === 0) continue;
              let payload;
              try { payload = JSON.parse(dataLines.join("\n")); } catch { continue; }
              handleEvent(event, payload);
            }
          }
        } catch (err) {
          addError(String(err));
        } finally {
          stopOnce();
          state.pending = false;
          sendBtn.disabled = false;
          input.focus();
        }
      }

      function handleEvent(event, payload) {
        switch (event) {
          case "session":
            if (payload.sessionId && payload.sessionId !== state.sessionId) {
              state.sessionId = payload.sessionId;
              sessionStorage.setItem("sessionId", payload.sessionId);
              renderMeta();
            }
            break;
          case "text":
            addTurn(payload.author, { markdown: true, text: payload.text });
            break;
          case "call":
            addToolCall(payload.author, payload.name, payload.args);
            break;
          case "result":
            addToolResult(payload.author, payload.name, payload.response);
            break;
          case "error":
            addError(payload.message);
            break;
          case "done":
            break;
        }
      }

      form.addEventListener("submit", (e) => {
        e.preventDefault();
        const msg = input.value.trim();
        if (!msg) return;
        input.value = "";
        input.style.height = "48px";
        send(msg);
      });

      input.addEventListener("keydown", (e) => {
        if (e.key === "Enter" && !e.shiftKey) {
          e.preventDefault();
          form.requestSubmit();
        }
      });

      function autoResize() {
        input.style.height = "48px";
        const next = Math.min(input.scrollHeight, 200);
        if (next > 48) input.style.height = next + "px";
      }
      input.addEventListener("input", autoResize);

      newBtn.addEventListener("click", () => {
        if (state.pending) return;
        sessionStorage.removeItem("sessionId");
        state.sessionId = null;
        log.innerHTML = "";
        renderMeta();
        input.focus();
      });

      input.focus();
    </script>
  </body>
</html>
